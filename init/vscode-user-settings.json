{
  // Mainly taken from other people, can't remember all
  // but I'm trying to track them now
  // https://dev.to/whizzzoe/how-i-set-up-vscode-for-productivity-checklist-omc

  "bookmarks.navigateThroughAllFiles": false,
  "breadcrumbs.enabled": false,

  "cSpell.userWords": [
    "gorshing",
    "pyserver",
    "tcpserver",
    "VENV"
  ],
  
  // "latex-workshop.latex.autoBuild.run": "never",

  // Most folks won't need this, but my wife
  // uses a screenreader and this keeps VSCode
  // from prompting me about it
  "editor.accessibilitySupport": "off",

  "editor.defaultFormatter": "esbenp.prettier-vscode",

  "editor.fontFamily": "Fira Code",
  //"editor.fontFamily": "Berkeley Mono Trial",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.renderWhitespace": "all",
  "editor.suggestSelection": "first",
  "editor.tabCompletion": "on",
  "editor.tabSize": 2,

  "elixirLS.dialyzerEnabled": false,

  "explorer.confirmDelete": false,

  "files.associations": {
    "*.log.*": "log",
    "log_*": "log",
    "*.now": "log",
    ".gitconfig-*": "properties",
  },

  "files.autoSave": "onFocusChange",
  "files.eol": "\n",
  "files.exclude": {
    "**/.classpath": true,
    "**/.idea/": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true,
    "**/.elixir_ls": true,
    "_build/": true,
    "**/._*": true,
    "deps/": true,
    "**/node_modules/": true,
    "**/__pycache__/": true
  },

  "files.trimTrailingWhitespace": true,


  "[log]": {
    "editor.fontLigatures": false
  },
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features",
    "editor.tabSize": 2
  },

  // "latex-workshop.docker.image.latex": "texlive/texlive",
  // "latex-workshop.docker.image.latex": "koppor/texlive",

  "[markdown]": {
    "files.trimTrailingWhitespace": false
  },

  "pylint.args": [
    // "--disable=C0114", // missing-module-docstring
    // "--disable=C0115", // missing-class-docstring
    // "--disable=C0116", // missing-function-docstring
    // "--disable=C0111", // No longer used, renamed to the 3 above


    "disable=missing-module-docstring",
    "disable=missing-class-docstring",
    "disable=missing-function-docstring",
    // "--errors-only"
  ],
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.tabSize": 4,
    "editor.formatOnType": true,
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {

      "source.organizeImports":"always",

      "python.analysis.autoImportCompletions":"always",

      "source.unusedImports": "always",
      "source.convertImportFormat": "always"
    },
  },
  "python.languageServer": "Pylance",
  "python.testing.pytestEnabled": true, // Can also be unittest, if both are enabled, then pytest is favored
  // "python.experiments.optOutFrom": ["pythonTestAdapter"],
  "python.experiments.optInto": ["pythonTestAdapter"],
  "isort.args":["--profile", "black"],

  "window.zoomLevel": 1,
  // "workbench.colorTheme": "Material Theme Darker",
  // "workbench.colorTheme": "Default Dark+",
  // "workbench.colorTheme": "Default Dark Modern",
  // "workbench.colorTheme": "Monokai",
  "workbench.colorTheme": "Dark Modern",
  "workbench.editorAssociations": {
     "*.ipynb": "jupyter-notebook",
  },
  "workbench.iconTheme": "vscode-icons",
  "remote.SSH.remotePlatform": {
    "trial1": "linux",
    "ubuntutrial": "linux",
    "10.17.76.171": "linux"
  },
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  },
  "chat.agent.enabled": true,
  "github.copilot.nextEditSuggestions.enabled": true,

  "vsicons.dontShowNewVersionMessage": true,

  "svelte.enable-ts-plugin": true
}