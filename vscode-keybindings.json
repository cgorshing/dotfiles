[
  {
    "key": "ctrl+alt+]",
    "command": "github.copilot.nextPanelSolution",
    "when": "github.copilot.activated && github.copilot.panelVisible"
  },
  {
    "key": "alt+]",
    "command": "-github.copilot.nextPanelSolution",
    "when": "github.copilot.activated && github.copilot.panelVisible"
  },

  {
    "key": "cmd+/",
    "command": "runCommands",
    "args": {
      "commands": [
        "editor.action.commentLine",
        "cursorDown"
      ]
    },
    "when": "editorTextFocus"
  },
  {
    "key": "shift+cmd+A",
    "command": "runCommands",
    "args": {
      "commands": [
        "editor.action.blockComment",
        "cursorDown"
      ]
    },
    "when": "editorTextFocus"
  }
]
